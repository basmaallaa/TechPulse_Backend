{
  "openapi": "3.0.4",
  "info": {
    "title": "TechPulse.PL",
    "version": "1.0"
  },
  "paths": {
    "/api/Post": {
      "get": {
        "tags": [
          "Post"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Post"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Category",
                  "Description",
                  "Title"
                ],
                "type": "object",
                "properties": {
                  "Title": {
                    "minLength": 5,
                    "type": "string"
                  },
                  "Category": {
                    "$ref": "#/components/schemas/Category"
                  },
                  "Image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "Description": {
                    "minLength": 20,
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "Title": {
                  "style": "form"
                },
                "Category": {
                  "style": "form"
                },
                "Image": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Post/{id}": {
      "delete": {
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Category": {
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  },
  "tags": [
    {
      "name": "Post"
    }
  ]
}